@model IEnumerable<carWorldDbFirstProject.Models.Cars>
<div class="container-fluid">
    <!--  Row 1 -->
    <div class="row">
        <div class="col-lg-12 d-flex align-items-stretch">
            <div class="card w-100">
                <div class="card-body p-4">
                    <h5 class="card-title fw-semibold mb-4">Araç Listesi</h5>

                    <div class="d-flex justify-content-between mb-3">

                        <form asp-action="Index" method="get" class="d-flex">
                            <input type="text"
                                   name="search"
                                   value="@ViewBag.Search"
                                   class="form-control me-2"
                                   placeholder="Marka veya model ara..." />

                            <button type="submit" class="btn btn-secondary">
                                Ara
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary ms-2">
                                Temizle
                            </a>
                        </form>

                        <a asp-action="Create" class="btn btn-primary">
                            Ekle
                        </a>

                    </div> <div class="table-responsive">
                        <table class="table text-nowrap mb-0 align-middle">
                            <thead class="text-dark fs-4">
                                <tr>
                                    <th class="border-bottom-0">
                                        <h6 class="fw-semibold mb-0">Id</h6>
                                    </th>
                                    <th class="border-bottom-0">
                                        <h6 class="fw-semibold mb-0">Marka/Model</h6>
                                    </th>
                                    <th class="border-bottom-0">
                                        <h6 class="fw-semibold mb-0">Fiyat</h6>
                                    </th>
                                    <th class="border-bottom-0">
                                        <h6 class="fw-semibold mb-0">Resim Url</h6>
                                    </th>
                                <th class="border-bottom-0 text-end">
                                        <h6 class="fw-semibold mb-0">Düzenle</h6>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                { 
                                <tr>
                                        <td class="border-bottom-0"><h6 class="fw-semibold mb-0">@item.Id</h6></td>
                                    <td class="border-bottom-0">
                                            <h6 class="fw-semibold mb-1">@item.Marka</h6>
                                            <span class="fw-normal">@item.Model</span>
                                    </td>
                                    <td class="border-bottom-0">
                                            <p class="mb-0 fw-normal">@item.Fiyat €</p>
                                    </td>
                                    <td class="border-bottom-0">
                                            <p class="mb-0 fw-normal">@item.ImageUrl </p>
                                    </td>
                               
                                    <td class="border-bottom-0 text-end">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-success">Düzenle</a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Sil</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>