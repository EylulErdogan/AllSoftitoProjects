@model IEnumerable<carWorldDbFirstProject.Models.Customers>
<div class="container-fluid">
    <!--  Row 1 -->
    <div class="row">
        <div class="col-lg-12 d-flex align-items-stretch">
            <div class="card w-100">
                <div class="card-body p-4">
                    <h5 class="card-title fw-semibold mb-4">Müşteri Listesi</h5>
                    <div class="d-flex justify-content-end mb-3"> <a asp-action="Create" class="btn btn-primary">Ekle</a></div>

                    <div class="table-responsive">
                        <table class="table text-nowrap mb-0 align-middle">
                            <thead class="text-dark fs-4">
                                <tr>
                                    <th class="border-bottom-0">
                                        <h6 class="fw-semibold mb-0">Id</h6>
                                    </th>
                                    <th class="border-bottom-0">
                                        <h6 class="fw-semibold mb-0">Ad soyad</h6>
                                    </th>
                                    <th class="border-bottom-0">
                                        <h6 class="fw-semibold mb-0">Telefon</h6>
                                    </th>
                                           <th class="border-bottom-0 text-end"> <h6 class="fw-semibold mb-0">İşlemler</h6> </th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="border-bottom-0"><h6 class="fw-semibold mb-0">@item.Id</h6></td>
                                        <td class="border-bottom-0">
                                            <h6 class="fw-semibold mb-1">@item.AdSoyad</h6>
                                        </td>
                                        <td class="border-bottom-0">
                                            <p class="mb-0 fw-normal">@item.Telefon </p>
                                        </td>
                                      
                                        <td class="border-bottom-0 text-end"> 
                                            <a asp-action="Edit" 
                                            asp-route-id="@item.Id" class="btn btn-success "> Düzenle </a> <a asp-action="Delete"
                                            asp-route-id="@item.Id" class="btn btn-danger ms-2"> Sil </a> </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>