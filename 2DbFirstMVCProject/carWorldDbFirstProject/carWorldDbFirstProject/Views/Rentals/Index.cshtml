@model IEnumerable<carWorldDbFirstProject.Models.Rentals>
<div class="container-fluid">
    <!--  Row 1 -->
    <div class="row">
        <div class="col-lg-12 d-flex align-items-stretch">
            <div class="card w-100">
                <div class="card-body p-4">
                    <h5 class="card-title fw-semibold mb-4">Recent Transactions</h5>
                    <div class="table-responsive">
                        <table class="table text-nowrap mb-0 align-middle">
                            <thead class="text-dark fs-4">
                                <tr>
                                    <th class="border-bottom-0">
                                        <h6 class="fw-semibold mb-0">Id</h6>
                                    </th>
                                    <th class="border-bottom-0">
                                        <h6 class="fw-semibold mb-0">Müşteri</h6>
                                    </th>
                                    <th class="border-bottom-0">
                                        <h6 class="fw-semibold mb-0">Marka/Model</h6>
                                    </th>
                                    <th class="border-bottom-0">
                                        <h6 class="fw-semibold mb-0">Teslim Alma</h6>
                                    </th>
                                    <th class="border-bottom-0">
                                        <h6 class="fw-semibold mb-0">Teslim Etme</h6>
                                    </th>
                                    <th class="border-bottom-0 text-end">
                                        <h6 class="fw-semibold mb-0">Düzenle</h6>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="border-bottom-0"><h6 class="fw-semibold mb-0">@item.Id</h6></td>
                                        <td class="border-bottom-0">
                                            <p class="mb-0 fw-normal">@item.Customers.AdSoyad </p>
                                        </td>
                                        <td class="border-bottom-0">
                                            <h6 class="fw-semibold mb-1">@item.Cars.Marka
                                            </h6>
                                            <span class="fw-normal">@item.Cars.Model</span>
                                        </td>
                                        <td class="border-bottom-0">
                                            <p class="mb-0 fw-normal">@item.BaslangicTarihi </p>
                                        </td>
                                        <td class="border-bottom-0">
                                            <p class="mb-0 fw-normal">@item.BitisTarihi </p>
                                        </td>
                                       
                                        <td class="border-bottom-0 text-end">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-success">Düzenle</a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Sil</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>