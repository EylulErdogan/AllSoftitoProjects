@model SporKulubu.Model.viewModel.AdminDashboardViewModel
<div class="main-panel">
    <div class="content-wrapper">
        <div class="row">
            <div class="col-lg-6 grid-margin stretch-card">
                <div class="card">
                    <div class="card-body">
                        <h3 class="card-title">Basic Table</h3>
                        <a href="@Url.ActionLink("Index", "Payment")">Tümünü Gör</a>
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Üye</th>
                                        <th>Tutar</th>
                                        <th>Ödeme Tarihi</th>
                                        <th>Durum</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.MemberPayments.Take(5))
                                    {
                                        var today = DateTime.Today;

                                        string badgeClass = "";
                                        string statusText = "";

                                        if (item.IsPaid)
                                        {
                                            badgeClass = "badge badge-success";
                                            statusText = "Ödendi";
                                        }
                                        else if (item.PaymentDate < today)
                                        {
                                            badgeClass = "badge badge-danger";
                                            statusText = "Geçti";
                                        }
                                        else
                                        {
                                            badgeClass = "badge badge-warning";
                                            statusText = "Yaklaşıyor";
                                        }

                                        <tr>
                                            <td>@item.MemberName</td>
                                            <td>@item.Amount TL</td>
                                            <td>@item.PaymentDate.ToShortDateString()</td>
                                            <td>
                                                <label class="@badgeClass">@statusText</label>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
             <div class="col-lg-6 grid-margin stretch-card">
     <div class="card">
         <div class="card-body">
             <h4 class="card-title">Spor Dalına Göre Üye</h4>
             <canvas id="barChart"></canvas>
         </div>
     </div>
 </div>
          
        </div>
    </div>
    <!-- content-wrapper ends -->
    <!-- partial:../../partials/_footer.html -->
    <footer class="footer">
        <div class="card">
            <div class="card-body">
                <div class="d-sm-flex justify-content-center justify-content-sm-between">
                    <span class="text-muted d-block text-center text-sm-left d-sm-inline-block">Copyright © bootstrapdash.com 2020</span>
                    <span class="float-none float-sm-right d-block mt-1 mt-sm-0 text-center"> Free <a href="https://www.bootstrapdash.com/" target="_blank">Bootstrap dashboard templates</a> from Bootstrapdash.com</span>
                </div>
            </div>
        </div>
    </footer>
    <!-- partial -->
</div>
@section Scripts {
    <script>
        var sportNames = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SportCounts.Select(x => x.SportName)));
        var memberCounts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SportCounts.Select(x => x.MemberCount)));

        var ctx = document.getElementById("barChart");

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: sportNames,
                datasets: [{
                    label: "Spor Dalına Göre Üye Sayısı",
                    data: memberCounts,
                    backgroundColor: ["#4B49AC", "#FFC100", "#248AFD", "#57B657", "#FF4747"]
                }]
            },
            options: {
                scales: {
                    yAxes: [{
                        ticks: {
                            beginAtZero: true,
                            stepSize: 1
                        }
                    }]
                }
            }
        });
    </script>
}