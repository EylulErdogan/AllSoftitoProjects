@model SporKulubu.Model.Payment

<div class="main-panel">
    <div class="content-wrapper">
        <div class="row">
            <div class="col-12 grid-margin stretch-card">
                <div class="card">
                    <div class="card-body">

                        <h4 class="card-title">Ödeme Ekle</h4>

                        <form asp-action="Create" method="post">

                            <div class="form-group">
                                <label>Üye</label>
                                <select asp-for="MemberId" asp-items="ViewBag.MemberId" class="form-control">
                                    <option value="">Üye Seçiniz</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label asp-for="Amount">Tutar</label>
                                <input asp-for="Amount" class="form-control" />
                            </div>

                            <div class="form-group">
                                <label asp-for="PaymentDate">Ödeme Tarihi</label>
                                <input asp-for="PaymentDate" type="date" class="form-control" />
                            </div>

                            <div class="form-group">
                                <label asp-for="PaymentType">Ödeme Tipi</label>
                                <select asp-for="PaymentType" class="form-control">
                                    <option value="">Ödeme Tipi Seçiniz</option>
                                    <option value="Nakit">Nakit</option>
                                    <option value="Kredi Kartı">Kredi Kartı</option>
                                    <option value="Banka Havalesi">Banka Havalesi</option>
                                    <option value="EFT">EFT</option>
                                </select>
                                <span asp-validation-for="PaymentType" class="text-danger"></span>
                            </div>
                            <div class="form-check">
                                <input asp-for="IsPaid" class="form-check-input" />
                                <label asp-for="IsPaid" class="form-check-label">
                                    Ödeme Yapıldı
                                </label>
                            </div>

                            <button type="submit" class="btn btn-primary mr-2">Kaydet</button>
                            <a asp-action="Index" class="btn btn-light">İptal</a>

                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>