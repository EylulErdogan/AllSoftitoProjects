@model IEnumerable<SporKulubu.Model.Payment>

<div class="main-panel">
    <div class="content-wrapper">
        <div class="row">
            <div class="col-lg-12 grid-margin stretch-card">
                <div class="card">
                    <div class="card-body">

                        <h4 class="card-title">Ödeme Listesi</h4>

                        <div class="d-flex justify-content-end mb-3 mr-2">
                            <a asp-action="Create" class="btn btn-primary">Ekle</a>
                        </div>

                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Id</th>
                                        <th>Üye</th>
                                        <th>Tutar</th>
                                        <th>Ödeme Tarihi</th>
                                        <th>Ödeme Tipi</th>
                                        <th>Statü</th>
                                        <th>Düzenle</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@item.Id</td>
                                            <td>@item.Member.FullName</td>
                                            <td>@item.Amount</td>
                                            <td>@item.PaymentDate.ToShortDateString()</td>
                                            <td>@item.PaymentType</td>
                                            <td>
                                                @if (item.IsPaid)
                                                {
                                                    <label class="badge badge-success">Ödendi</label>
                                                }
                                                else if (item.PaymentDate < DateTime.Now)
                                                {
                                                    <label class="badge badge-danger">Süresi Geçti</label>
                                                }
                                                else if (item.PaymentDate <= DateTime.Now.AddDays(7))
                                                {
                                                    <label class="badge badge-warning">Yaklaşıyor</label>
                                                }
                                                else
                                                {
                                                    <label class="badge badge-info">Bekleniyor</label>
                                                }
                                            </td>
                                            <td>
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-success">Edit</a>
                                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Sil</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>