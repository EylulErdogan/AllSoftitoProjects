@model IEnumerable<SporKulubu.Model.Member >

<div class="main-panel">
    <div class="content-wrapper">
        <div class="row">
            <div class="col-lg-12 grid-margin stretch-card">
                <div class="card">
                   
                    <div class="card-body">

                        <h4 class="card-title">Üye Listesi</h4>
                        <p class="card-description">
                            Add class <code>.table</code>
                        </p>
                        <div class="d-flex justify-content-end mb-3 mr-2">
                            <a asp-action="Create" class="btn btn-primary">
                                <i class="fas fa-plus"></i> Ekle
                            </a>
                        </div>
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>

                                        <th>Id</th>
                                        <th>İsim Soyisim</th>
                                        <th>Yaş</th>
                                        <th>Telefon</th>
                                        <th>Email</th>
                                        <th>Düzenle</th>
                                        <th>Spor Dalı</th>
                                       
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach(var item in Model)
                                    {
                                        <tr>
                                            <td>@item.Id</td>
                                            <td>@item.FullName</td>
                                            <td>@item.Age</td>
                                            <td>@item.Phone</td>
                                            <td>@item.Email</td>
                                            <td>@item.Sport.SportName</td>
                                            <td>
                                                
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-success">Edit</a>
                                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Sil</a>
                                            </td>
                                           </tr>
                                    }
                                    
                                   
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
    
          
        </div>
    </div>
    <!-- content-wrapper ends -->
    <!-- partial:../../partials/_footer.html -->
    <footer class="footer">
        <div class="card">
            <div class="card-body">
                <div class="d-sm-flex justify-content-center justify-content-sm-between">
                    <span class="text-muted d-block text-center text-sm-left d-sm-inline-block">Copyright © bootstrapdash.com 2020</span>
                    <span class="float-none float-sm-right d-block mt-1 mt-sm-0 text-center"> Free <a href="https://www.bootstrapdash.com/" target="_blank">Bootstrap dashboard templates</a> from Bootstrapdash.com</span>
                </div>
            </div>
        </div>
    </footer>
    <!-- partial -->
</div>