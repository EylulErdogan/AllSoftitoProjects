@model SporKulubu.Model.Member

<div class="main-panel">
    <div class="content-wrapper">
        <div class="row">
            <div class="col-12 grid-margin stretch-card">
                <div class="card">
                    <div class="card-body">

                        <h4 class="card-title">Üye Güncelle</h4>

                        <form asp-action="Edit" method="post">

                            <input type="hidden" asp-for="Id" />

                            <div class="form-group">
                                <label asp-for="FullName">Ad Soyad</label>
                                <input asp-for="FullName" class="form-control" />
                            </div>

                            <div class="form-group">
                                <label asp-for="Age">Yaş</label>
                                <input asp-for="Age" class="form-control" />
                            </div>

                            <div class="form-group">
                                <label asp-for="Phone">Telefon</label>
                                <input asp-for="Phone" class="form-control" />
                            </div>

                            <div class="form-group">
                                <label asp-for="Email">Email</label>
                                <input asp-for="Email" class="form-control" />
                            </div>

                            <div class="form-group">
                                <label>Spor Dalı</label>
                                <select asp-for="SportId" asp-items="ViewBag.SportId" class="form-control">
                                    <option value="">Spor Seçiniz</option>
                                </select>
                            </div>

                            <button type="submit" class="btn btn-primary mr-2">
                                Güncelle
                            </button>

                            <a asp-action="Index" class="btn btn-light">
                                İptal
                            </a>

                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>