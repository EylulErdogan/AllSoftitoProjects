@model IEnumerable<SporKulubu.Model.Coach>

<div class="main-panel">
    <div class="content-wrapper">
        <div class="row">
            <div class="col-lg-12 grid-margin stretch-card">
                <div class="card">

                    <div class="card-body">

                        <h4 class="card-title">Koç Listesi</h4>

                        <div class="d-flex justify-content-end mb-3 mr-2">
                            <a asp-action="Create" class="btn btn-primary">
                                <i class="fas fa-plus"></i> Ekle
                            </a>
                        </div>

                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Id</th>
                                        <th>İsim Soyisim</th>
                                        <th>Telefon</th>
                                        <th>Email</th>
                                        <th>Maaş</th>
                                        <th>Spor Dalı</th>
                                        <th>Düzenle</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@item.Id</td>
                                            <td>@item.FullName</td>
                                            <td>@item.Phone</td>
                                            <td>@item.Email</td>
                                            <td>@item.Salary</td>
                                            <td>@item.Sport.SportName</td>
                                            <td>
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-success">
                                                    Edit
                                                </a>
                                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">
                                                    Sil
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                    </div>

                </div>
            </div>
        </div>
    </div>
</div>