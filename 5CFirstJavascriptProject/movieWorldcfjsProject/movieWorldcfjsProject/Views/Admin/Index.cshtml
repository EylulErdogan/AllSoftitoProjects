

<section class="section section--first section--bg" data-bg="/flixgo/img/section/section.jpg">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="section__wrap">
                    <h2 class="section__title">Film Ekle</h2>

                    <ul class="breadcrumb">
                        <li class="breadcrumb__item"><a href="/Home/Index">Home</a></li>
                        <li class="breadcrumb__item"><a href="/Admin/Index">Admin Film Ekle</a></li>
                        <li class="breadcrumb__item breadcrumb__item--active"><a href="/Admin/editpanel">Güncelleme İşlemleri</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>
</br>
</br>
</br>
</br>
