@model ShoeStoreApi.Models.Brand

@{
    Layout = "_AdminLayout";
}

<div class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-8">

                <div class="card">
                    <div class="header">
                        <h4 class="title">Marka Güncelle</h4>
                    </div>

                    <div class="content">

                        <form asp-action="Edit" asp-controller="Brand" method="post">

                            <input type="hidden" asp-for="Id" />

                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                            <div class="row">
                                <div class="col-md-12">
                                    <div class="form-group">
                                        <label>Marka Adı</label>

                                        <input asp-for="BrandName"
                                               class="form-control"
                                               placeholder="Marka adı giriniz" />

                                        <span asp-validation-for="BrandName"
                                              class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <button type="submit"
                                    class="btn btn-info btn-fill pull-right">
                                Güncelle
                            </button>

                            <a asp-action="Index"
                               asp-controller="Brand"
                               class="btn btn-secondary">
                                Geri Dön
                            </a>

                            <div class="clearfix"></div>

                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>
</div>