@model List<ShoeStoreApi.Models.Category>
@{
    Layout = "_AdminLayout";
}
<div class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="header">
                        <h4 class="title">Kategori Listesi</h4>
                        <p class="category">Kategori işlemlerini bu tablodan yapabilirsiniz.</p>
                        <a asp-action="Create" type="submit" class="btn btn-info btn-fill pull-right">Ekle</a>
                      
                    </div>
                    <div class="content table-responsive table-full-width">
                        <table class="table table-hover table-striped">
                            <thead>
                                <th>ID</th>
                                <th>Kategori Name</th>
                                <th class="text-end">Düzenle</th>
                            </thead>
                            <tbody>
                                @foreach(var item in Model)
                                {
                                    <tr>
                                        <td> @item.Id</td>
                                        <td> @item.CategoryName</td>
                                       <td class="text-end">
    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-success btn-sm">
        Güncelle
    </a>

    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
        Sil
    </a>
</td>
                                    </tr>
                                }
                                
                           
                            </tbody>
                        </table>

                    </div>
                </div>
            </div>


        


        </div>
    </div>
</div>