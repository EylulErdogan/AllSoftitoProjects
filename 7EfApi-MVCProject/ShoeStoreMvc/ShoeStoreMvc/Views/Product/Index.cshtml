<section id="selling-product" class="single-product py-2 my-2 py-md-5 my-md-5">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-8">
                <div class="row flex-column-reverse flex-lg-row">
                    <div class="col-md-12 col-lg-2">
                        <!-- product-thumbnail-slider -->
                        <div class="swiper product-thumbnail-slider swiper-initialized swiper-vertical swiper-backface-hidden swiper-thumbs">
                            <div class="swiper-wrapper" id="swiper-wrapper-21ab19b24981c10ad" aria-live="polite" style="transform: translate3d(0px, 0px, 0px);">
                               
                                <div class="swiper-slide swiper-slide-visible swiper-slide-next" style="height: 130px; margin-bottom: 10px;" role="group" aria-label="2 / 5">
                                    <img src="@Model.ImageUrl" alt="" class="thumb-image img-fluid">
                                </div>
                            
                              
                               
                            </div>
                            <span class="swiper-notification" aria-live="assertive" aria-atomic="true"></span>
                        </div>
                        <!-- / product-thumbnail-slider -->
                    </div>
                    <div class="col-md-12 col-lg-10">
                        <!-- product-large-slider -->
                        <div class="swiper product-large-slider swiper-fade swiper-initialized swiper-horizontal swiper-watch-progress swiper-backface-hidden">
                            <div class="swiper-wrapper" id="swiper-wrapper-42de9b389af63d10d" aria-live="polite">
                              
                                <div class="swiper-slide swiper-slide-next" style="width: 689px; opacity: 0; transform: translate3d(-689px, 0px, 0px);" role="group" aria-label="2 / 5">
                                    <div class="image-zoom" data-scale="2.5" data-image="@Model.ImageUrl"><img src="@Model.ImageUrl" alt="product-large" class="img-fluid"></div>
                                </div>
                             
                            </div>
                            <div class="swiper-pagination swiper-pagination-clickable swiper-pagination-bullets swiper-pagination-horizontal"><span class="swiper-pagination-bullet swiper-pagination-bullet-active" tabindex="0" role="button" aria-label="Go to slide 1" aria-current="true"></span><span class="swiper-pagination-bullet" tabindex="0" role="button" aria-label="Go to slide 2"></span><span class="swiper-pagination-bullet" tabindex="0" role="button" aria-label="Go to slide 3"></span><span class="swiper-pagination-bullet" tabindex="0" role="button" aria-label="Go to slide 4"></span><span class="swiper-pagination-bullet" tabindex="0" role="button" aria-label="Go to slide 5"></span></div>
                            <span class="swiper-notification" aria-live="assertive" aria-atomic="true"></span>
                        </div>
                        <!-- / product-large-slider -->
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="product-info">
                    <div class="element-header">
                        <h3 itemprop="name" class="display-6 fw-bold">@Model.ShoeName</h3>
                    </div>
                    <div class="product-price py-3">
                        <strong class="fs-5 fw-bold">@Model.Price ₺</strong>
                    </div>
                    <p>
                        @Model.BrandName
                    </p>
                
                       
                        <div class="product-quantity">
                            <div class="stock-number text-dark">Stokta @Model.Stock Adet</div>
                            <div class="stock-button-wrap pt-3">
                                <div class="quantity-price d-flex justify-content-between align-items-center">
                                    <div class="input-group product-qty">
                                        <button type="button" class="quantity-left-minus btn btn-light rounded-0 rounded-start btn-number" data-type="minus">
                                            <svg width="16" height="16">
                                                <use xlink:href="#minus"></use>
                                            </svg>
                                        </button>
                                        <input type="text" name="quantity" class="form-control input-number quantity" value="1">
                                        <button type="button" class="quantity-right-plus btn btn-light rounded-0 rounded-end btn-number" data-type="plus">
                                            <svg width="16" height="16">
                                                <use xlink:href="#plus"></use>
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                                <!-- quantity-price -->
                                <div class="qty-button d-flex flex-wrap pt-3">
                                    <button type="submit" class="btn btn-black text-uppercase me-3 mt-3 hvr-sweep-to-right">
                                        Buy
                                        now
                                    </button>
                                    <button type="submit" name="add-to-cart" value="1269" class="btn btn-outline-gray text-uppercase mt-3 hvr-sweep-to-right">Add to cart</button>
                                </div>
                            </div>
                        </div>
                    </div>
                  
                </div>
            </div>
        </div>
    </div>
</section>