@model List<MyDpprProject.Models.Sale>

@{
    Layout = "_AdminLayout";
}

<div class="container-fluid my-4 px-lg-4">

    <div class="d-flex justify-content-between align-items-center">
        <h2 class="fw-bold m-0">Satış Listesi</h2>

        <nav class="breadcrumb m-0">
            <a class="breadcrumb-item" href="/Admin">Anasayfa</a>
            <a class="breadcrumb-item" href="/Sale">Satışlar</a>
            <span class="breadcrumb-item active" aria-current="page">Satış Listesi</span>
        </nav>
    </div>

    <div class="bg-white p-4 mt-4">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <select class="form-select w-auto d-inline">
                    <option>10</option>
                    <option>25</option>
                    <option>50</option>
                </select> entries
            </div>

          
        </div>

        <table class="table table-hover align-middle bg-white">

            <thead class="table-light">
                <tr>
                    <th>Satış ID</th>
                    <th>İlan</th>
                    <th>Adres</th>
                    <th>Müşteri</th>
                    <th>Satış Tarihi</th>
                    <th>Toplam Tutar</th>
                    <th>Düzenle</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>@item.SaleId</td>

                        <td>@item.Title</td>

                        <td>@item.Address</td>

                        <td>@item.FullName</td>

                        <td>@item.SaleDate.ToString("dd.MM.yyyy")</td>

                        <td>@item.TotalPrice.ToString("N0") ₺</td>

                        <td>

                            <a href="@Url.Action("UpdateSale", "Sale", new { id = item.SaleId })"
                               class="text-success me-2">
                                <i class="bi bi-pencil-square"></i>
                            </a>

                            <a href="@Url.Action("DeleteSale", "Sale", new { id = item.SaleId })"
                               class="text-danger"
                               onclick="return confirm('Bu satış kaydı silinsin mi?')">
                                <i class="bi bi-trash-fill"></i>
                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

        <nav>
            <ul class="pagination justify-content-end">
                <li class="page-item"><a class="page-link" href="#">«</a></li>
                <li class="page-item active"><a class="page-link" href="#">1</a></li>
                <li class="page-item"><a class="page-link" href="#">2</a></li>
                <li class="page-item"><a class="page-link" href="#">3</a></li>
                <li class="page-item"><a class="page-link" href="#">»</a></li>
            </ul>
        </nav>

    </div>

</div>