@model MyDpprProject.Models.PropertyType

@{
    Layout = "_AdminLayout";
}

<div class="container-fluid my-4 px-lg-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2 class="fw-bold m-0">New Property</h2>
        <nav class="breadcrumb m-0">
            <a class="breadcrumb-item" href="/PropertyType/Index">Property</a>
            <span class="breadcrumb-item active">Yeni Tip</span>
        </nav>
    </div>

    <form method="post">
        <div class="row mt-4">
            <div class="col-lg-12">
                <div class="p-4 bg-white border rounded">

                    <div class="mb-3">
                        <label class="form-label">Tip Adı *</label>
                        <input type="text" asp-for="TypeName" class="form-control p-3" placeholder="İlan Tipi Gİriniz">
                    </div>

                    
                    <div class="col-lg-3 mt-5 mt-lg-0">

       
                        <div class="mt-3 d-flex gap-2">
                            <button type="submit" class="btn btn-dark py-3 w-100">İlan Tipi OLuştur</button>
                            <a href="/PropertyType/Index" class="btn btn-outline-dark py-3 w-100">İptal</a>
                        </div>
                    </div>
                </div>

            </div>

          
        </div>
    </form>
</div>