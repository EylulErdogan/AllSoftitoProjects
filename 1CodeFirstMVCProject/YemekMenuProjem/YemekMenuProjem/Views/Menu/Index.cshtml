@model IEnumerable<YemekMenuProjem.Models.Menu>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<section id="the-menu">
    <div class="section-inner">

        <div class="container">
            <div class="row">
                <div class="col-lg-12 text-center mb100">
                    <h2 class="section-heading"> <span class="theme-accent-color">Menu</span> </h2>
                    <hr class="thin-hr">
                    <h3 class="section-subheading secondary-font">Damak tadınız size teşekkür edecek.</h3>
                </div>
            </div>
        </div>

        <div class="container">

       

            <div class="row">

               
                <div class="col-md-6 wow fadeIn">
                    <h2 class="mb50"><span class="heading-font text-uppercase">Başangıçlar</span></h2>
                    @foreach (var item in Model.Where(x => x.KategoriId == 1))
                    {
                        <div class="food-menu-item">
                            <div class="row">
                                <div class="col-xs-3">
                                    <img src="@Url.Content(item.ResimUrl)" class="img-responsive" />
                                </div>

                                <div class="col-xs-9">
                                    <h3>
                                        @item.YemekAdi
                                        <span class="theme-accent-color">@item.Fiyat TL</span>
                                    </h3>

                                    <p>@item.Aciklama</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>


               
                <div class="col-md-6 wow fadeIn">
                    <h2 class="mb50"><span class="heading-font text-uppercase">Ana Yemekler</span></h2>
                    @foreach (var item in Model.Where(x => x.KategoriId == 2))
                    {
                        <div class="food-menu-item">
                            <div class="row">
                                <div class="col-xs-3">
                                    <img src="@Url.Content(item.ResimUrl)" class="img-responsive">
                                </div>
                                <div class="col-xs-9">
                                    <h3>@item.YemekAdi <span class="theme-accent-color">@item.Fiyat TL</span></h3>
                                    <p>@item.Aciklama TL</p>
                                </div>
                            </div>
                        </div>
                    }

                </div>

            </div>
        </div>
    </div>
</section>















