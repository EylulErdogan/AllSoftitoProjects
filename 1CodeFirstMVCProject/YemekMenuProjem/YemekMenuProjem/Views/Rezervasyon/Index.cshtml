@model IEnumerable<YemekMenuProjem.Models.Rezervasyon>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="" />
    <meta name="author" content="" />
    <title>Tables - SB Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/simple-datatables@7.1.2/dist/style.min.css" rel="stylesheet" />
    <link href="~/admintemplate/css/styles.css" rel="stylesheet" />
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
</head>

<body class="sb-nav-fixed">
    <nav class="sb-topnav navbar navbar-expand navbar-dark bg-dark">
        <!-- Navbar Brand-->
        <a class="navbar-brand ps-3" href="index.html">Start Bootstrap</a>
        <!-- Sidebar Toggle-->
        <button class="btn btn-link btn-sm order-1 order-lg-0 me-4 me-lg-0" id="sidebarToggle" href="#!"><i class="fas fa-bars"></i></button>

    </nav>
    <div id="layoutSidenav">
        <div id="layoutSidenav_nav">
            <nav class="sb-sidenav accordion sb-sidenav-dark" id="sidenavAccordion">
                <div class="sb-sidenav-menu">
                    <div class="nav">
                        <div class="sb-sidenav-menu-heading">Dashboard Düzenlemeleri</div>
                        <a class="nav-link" href="@Url.ActionLink("AdminMenu", "Menu")">
                            <div class="sb-nav-link-icon"><i class="fas fa-tachometer-alt"></i></div>
                            Menü İşlemleri
                        </a>
                        <a class="nav-link" href="@Url.ActionLink("Index", "Category")">
                            <div class="sb-nav-link-icon"><i class="fas fa-tachometer-alt"></i></div>
                            Kategori İşlemleri
                        </a>
                        <a class="nav-link" href="@Url.ActionLink("Index", "Rezervasyon")">
                            <div class="sb-nav-link-icon"><i class="fas fa-tachometer-alt"></i></div>
                            Rezervasyon İşlemleri
                        </a>
                        <a class="nav-link" href="@Url.ActionLink("Index", "Masa")">
                            <div class="sb-nav-link-icon"><i class="fas fa-tachometer-alt"></i></div>
                            Masa İşlemleri
                        </a>
                        <a class="nav-link" href="@Url.ActionLink("Index", "Rapor")">
                            <div class="sb-nav-link-icon"><i class="fas fa-tachometer-alt"></i></div>
                            Rapor İşlemleri
                        </a>
                  
                    </div>
                </div>
                <div class="sb-sidenav-footer">
                    Food World
                </div>
            </nav>
        </div>
        <div id="layoutSidenav_content">
            <main>
                <div class="container-fluid px-4">
                    <h1 class="mt-4">Rezervasyon Listesi</h1>
                    <ol class="breadcrumb mb-4">
                    </ol>
                    <div class="d-flex justify-content-end mb-3">
                        <a asp-action="Create" class="btn btn-primary">
                            <i class="fas fa-plus"></i> Ekle
                        </a>
                    </div>
                    <div class="card mb-4">
                        <div class="card-header">
                            <i class="fas fa-table me-1"></i>
                            Aktif
                        </div>
                        <div class="card-body">
                            <table id="datatablesSimple">
                                <thead>
                                    <tr>
                                        <th>MusteriAdSoyad</th>
                                        <th>Telefon </th>
                                        <th>RezervasyonTarihi</th>
                                        <th>KisiSayisi</th>
                                        <th>Masa</th>
                                        <th>Notlar</th>
                                        <th>Düzenle</th>
                                    </tr>
                                </thead>

                                <tfoot>
                                    <tr>
                                        <th>MusteriAdSoyad</th>
                                        <th>Telefon </th>
                                        <th>RezervasyonTarihi</th>
                                        <th>KisiSayisi</th>
                                        <th>Masa</th>
                                        <th>Notlar</th>
                                        <th>Düzenle</th>


                                    </tr>
                                </tfoot>
                                <tbody>

                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@item.MusteriAdSoyad</td>
                                            <td>@item.Telefon</td>
                                            <td>@item.RezervasyonTarihi</td>
                                            <td>@item.KisiSayisi</td>
                                            <td>@item.Masa</td>
                                            <td>@item.Notlar</td>
                                            <td>
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-success">Edit</a>
                                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Sil</a>
                                            </td>
                                        </tr>
                                    }

                               
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </main>

        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script src="~/admintemplate/js/scripts.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/simple-datatables@7.1.2/dist/umd/simple-datatables.min.js" crossorigin="anonymous"></script>
    <script src="~/admintemplate/js/datatables-simple-demo.js"></script>
</body>
</html>
